<Application x:Class="FrostedTXT.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utils="clr-namespace:FrostedTXT.App.Infrastructure.Utils"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Frosted.Colors.xaml" />
                <ResourceDictionary Source="Themes/Frosted.Typography.xaml" />
                <ResourceDictionary Source="Themes/Frosted.Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <utils:BoolToWrapConverter x:Key="BoolToWrapConverter" />
            <utils:MultiplyDoubleConverter x:Key="MultiplyDoubleConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
