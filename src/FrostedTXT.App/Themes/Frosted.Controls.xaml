<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style TargetType="Window">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource FrostForegroundBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="Background" Value="#18FFFFFF" />
        <Setter Property="Foreground" Value="{StaticResource FrostForegroundBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource FrostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="Margin" Value="2" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource FrostForegroundBrush}" />
        <Setter Property="Background" Value="#12000000" />
        <Setter Property="BorderBrush" Value="{StaticResource FrostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background" Value="#10000000" />
        <Setter Property="Foreground" Value="{StaticResource FrostForegroundBrush}" />
        <Setter Property="Margin" Value="2,0" />
    </Style>

    <Style TargetType="TextBox" BasedOn="{StaticResource InputTextStyle}" />

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource FrostForegroundBrush}" />
        <Setter Property="Background" Value="#FF1E1E1E" />
    </Style>

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="#FF1E1E1E" />
        <Setter Property="BorderBrush" Value="{StaticResource FrostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>
</ResourceDictionary>
