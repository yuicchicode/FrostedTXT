<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="BaseTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FrostForegroundBrush}" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <Style x:Key="InputTextStyle" TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource FrostForegroundBrush}" />
        <Setter Property="Background" Value="#22000000" />
        <Setter Property="BorderBrush" Value="{StaticResource FrostBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="8" />
    </Style>
</ResourceDictionary>
