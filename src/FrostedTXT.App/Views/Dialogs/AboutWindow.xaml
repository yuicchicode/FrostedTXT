<Window x:Class="FrostedTXT.App.Views.Dialogs.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About FrostedTXT"
        Icon="pack://application:,,,/Assets/icon.ico"
        Height="240"
        Width="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Image Grid.Row="0"
               Grid.RowSpan="2"
               Grid.Column="0"
               Source="pack://application:,,,/Assets/app-logo.png"
               Width="48"
               Height="48"
               Margin="0,0,12,0" />

        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   Text="{Binding AppName}"
                   FontSize="22"
                   FontWeight="Bold" />
        <TextBlock Grid.Row="1"
                   Grid.Column="1"
                   Text="{Binding Version, StringFormat=Version {0}}"
                   Margin="0,6,0,0" />
        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="2"
                   Text="{Binding Description}"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0" />
        <Button Grid.Row="3"
                Grid.ColumnSpan="2"
                Content="Close"
                Width="88"
                HorizontalAlignment="Right"
                Click="Close_OnClick" />
    </Grid>
</Window>
