<Window x:Class="FrostedTXT.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:FrostedTXT.App.Controls"
        mc:Ignorable="d"
        Title="FrostedTXT"
        Icon="pack://application:,,,/Assets/icon.ico"
        Height="700"
        Width="980"
        MinHeight="450"
        MinWidth="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Window.Resources>
        <Style x:Key="HeaderOnlyTabControlStyle" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False"
                                          Focusable="False"
                                          Padding="0,2,0,2">
                                <TabPanel IsItemsHost="True"
                                          Background="Transparent"
                                          Margin="0" />
                            </ScrollViewer>
                            <ContentPresenter x:Name="PART_SelectedContentHost"
                                              Visibility="Collapsed"
                                              ContentSource="SelectedContent" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="EditorContentTemplate">
            <Border Background="#0DFFFFFF"
                    BorderBrush="{StaticResource FrostSeparatorBrush}"
                    BorderThickness="1"
                    Padding="0"
                    Margin="0"
                    CornerRadius="14">
                <TextBox Text="{Binding TextContent, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="{Binding DataContext.Settings.WordWrapEnabled, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToWrapConverter}}"
                         FontFamily="{Binding DataContext.Settings.FontFamilyName, RelativeSource={RelativeSource AncestorType=Window}}"
                         BorderThickness="0"
                         Padding="20"
                         Background="Transparent">
                    <TextBox.FontSize>
                        <MultiBinding Converter="{StaticResource MultiplyDoubleConverter}">
                            <Binding Path="DataContext.Settings.FontSizeBase" RelativeSource="{RelativeSource AncestorType=Window}" />
                            <Binding Path="DataContext.Settings.ZoomLevel" RelativeSource="{RelativeSource AncestorType=Window}" />
                        </MultiBinding>
                    </TextBox.FontSize>
                </TextBox>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="14">
        <Border CornerRadius="12"
                BorderBrush="{StaticResource FrostBorderBrush}"
                BorderThickness="1"
                Background="{Binding Settings.TintColor}"
                Opacity="{Binding Settings.BackgroundOpacity}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24"
                                  ShadowDepth="0"
                                  Opacity="0.24"
                                  Color="#AA000000" />
            </Border.Effect>
        </Border>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="12,6,10,0" PreviewMouseLeftButtonDown="HeaderRow_OnPreviewMouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border x:Name="DragRegion"
                        Grid.ColumnSpan="3"
                        Background="Transparent" />

                <Border Grid.Column="0"
                        Width="32"
                        Height="32"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Background="Transparent">
                    <Image Source="pack://application:,,,/Assets/app-logo.png"
                           Width="22"
                           Height="22"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
                </Border>

                <TabControl Grid.Column="1"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Height="40"
                            ItemsSource="{Binding Tabs}"
                            SelectedItem="{Binding SelectedTab}"
                            Style="{StaticResource HeaderOnlyTabControlStyle}">
                    <TabControl.ItemTemplate>
                        <DataTemplate>
                            <controls:TabHeaderControl />
                        </DataTemplate>
                    </TabControl.ItemTemplate>
                </TabControl>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="+"
                            Width="30"
                            Height="30"
                            VerticalAlignment="Center"
                            Command="{Binding NewTabCommand}" />
                    <controls:DropdownMenuButton Margin="0,0,6,0"
                                                 VerticalAlignment="Center"
                                                 NewTabCommand="{Binding NewTabCommand}"
                                                 OpenCommand="{Binding OpenCommand}"
                                                 SaveCommand="{Binding SaveCommand}"
                                                 SaveAsCommand="{Binding SaveAsCommand}"
                                                 SettingsCommand="{Binding OpenSettingsCommand}"
                                                 AboutCommand="{Binding OpenAboutCommand}"
                                                 ExitCommand="{Binding CloseAppCommand}" />
                    <Button Content="_" Width="34" Height="30" Click="Minimize_OnClick" />
                    <Button Content="[]" Width="34" Height="30" Click="MaxRestore_OnClick" />
                    <Button Content="X" Width="34" Height="30" Click="Close_OnClick" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="12,0,12,12">
                <ContentControl Content="{Binding SelectedTab}"
                                ContentTemplate="{StaticResource EditorContentTemplate}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
